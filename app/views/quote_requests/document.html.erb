<section class="hero hero--compact quote-doc">
  <div>
    <p class="eyebrow"><%= quote_or_order_label %> Document</p>
    <h2><%= OrderDocumentCopy.heading %></h2>
    <p class="lead">
      <strong><%= @quote_request.quote_number %></strong>
      <% if @quote_request.customer_reference.present? %>
        | Ref: <%= @quote_request.customer_reference %>
      <% end %>
    </p>
  </div>
  <span class="status-pill status-pill--<%= @quote_request.status %>"><%= @quote_request.display_status %></span>
</section>

<section class="panel quote-doc-sheet">
  <p class="quote-doc-sheet__intro"><%= OrderDocumentCopy.intro %></p>
  <%= render "quote_requests/order_lines_sheet",
             quote_request: @quote_request,
             blank_value: "",
             minimum_rows: 12,
             sheet_class: "order-lines-sheet--document" %>

  <div class="quote-doc-sheet__legal">
    <p><strong>Valid Until:</strong> <%= l(@quote_request.valid_until, format: :long) %></p>
    <p><%= OrderDocumentCopy.terms %></p>
    <p><%= OrderDocumentCopy.footer %></p>
  </div>
</section>

<div class="actions no-print">
  <button class="button button--secondary" onclick="window.print()">Print / Save as PDF</button>
  <% if current_user.admin? %>
    <%= link_to "Back to Admin #{quote_or_order_label}", admin_quote_request_path(@quote_request), class: "button button--primary" %>
  <% else %>
    <%= link_to "Back to #{quote_or_order_label}", quote_request_path(@quote_request), class: "button button--primary" %>
  <% end %>
</div>
