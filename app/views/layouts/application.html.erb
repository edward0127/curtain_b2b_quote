<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Curtain B2b Quote" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Curtain B2b Quote">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= if render_public_shell?
    "app-body app-body--public public-page public-page--#{controller_name.dasherize}-#{action_name.dasherize} public-heading-font-#{public_font_class(:public_heading_font)} public-body-font-#{public_font_class(:public_body_font)}"
  else
    "app-body app-body--portal"
  end %>">
    <% if !render_public_shell? %>
      <main class="app-shell">
        <header class="topbar card card--blur">
          <div>
            <p class="eyebrow">Operations Workspace</p>
            <h1 class="topbar__title">Curtain B2B Quote Portal</h1>
          </div>

          <div class="topbar__right">
            <p class="user-chip">
              <strong><%= current_user.email %></strong>
              <span>
                <%= current_user.role.humanize %>
                <% if impersonating? && impersonator_admin_user.present? %>
                  (Impersonated by <%= impersonator_admin_user.email %>)
                <% end %>
              </span>
            </p>

            <nav class="topbar__nav">
              <%= link_to "Dashboard", dashboard_path, data: { turbo_frame: "_top" } %>
              <% if current_user.admin? %>
                <%= link_to "Manage Customers", dashboard_path(tab: :customers, compact: 1), data: { turbo_frame: "_top" } %>
                <%= link_to "Quotes Workflow", admin_quote_requests_path, data: { turbo_frame: "_top" } %>
                <%= link_to "Products", admin_products_path, data: { turbo_frame: "_top" } %>
                <%= link_to "Templates", admin_quote_templates_path, data: { turbo_frame: "_top" } %>
                <%= link_to "Jobs", admin_jobs_path, data: { turbo_frame: "_top" } %>
                <%= link_to "Open System Settings", dashboard_path(tab: :settings, compact: 1), data: { turbo_frame: "_top" } %>
                <%= link_to "Edit Pages", edit_pages_path, data: { turbo_frame: "_top" } %>
              <% else %>
                <%= link_to "Submit a New Quote", dashboard_path(tab: :new_quote), data: { turbo_frame: "_top" } %>
                <%= link_to "View Full Quote History", dashboard_path(tab: :history), data: { turbo_frame: "_top" } %>
                <% if impersonating? && impersonator_admin_user.present? %>
                  <%= button_to "Return to Admin", impersonation_path, method: :delete, class: "button button--secondary", form: { class: "inline-form" } %>
                <% end %>
              <% end %>
              <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "button button--ghost", form: { class: "inline-form" } %>
            </nav>
          </div>
        </header>

        <% if notice.present? || alert.present? %>
          <div class="flash-stack">
            <% if notice.present? %>
              <div class="flash flash--notice" data-controller="flash" data-flash-timeout-value="6000">
                <div class="flash__content"><%= notice %></div>
                <button type="button" class="flash__close" data-action="flash#close" aria-label="Dismiss notification">&times;</button>
              </div>
            <% end %>
            <% if alert.present? %>
              <div class="flash flash--alert" data-controller="flash" data-flash-timeout-value="9000">
                <div class="flash__content"><%= alert %></div>
                <button type="button" class="flash__close" data-action="flash#close" aria-label="Dismiss alert">&times;</button>
              </div>
            <% end %>
          </div>
        <% end %>

        <section class="content card card--content">
          <%= yield %>
        </section>

        <footer class="legal-footer">
          <%= link_to "Terms of Service", terms_path %>
          <span>|</span>
          <%= link_to "Privacy Policy", privacy_path %>
          <span>|</span>
          <span>
            Website designed by
            <%= link_to "Tudouke Studio", "https://tudouke.com", target: "_blank", rel: "noopener" %>
          </span>
        </footer>
      </main>
    <% else %>
      <% admin_public = current_user&.admin? %>
      <% edit_mode = public_edit_mode? %>
      <% home_nav_path = edit_mode ? edit_pages_path : root_path %>
      <% partners_nav_path = edit_mode ? edit_partners_page_path : partners_path %>
      <% builders_nav_path = edit_mode ? edit_builders_page_path : builders_path %>

      <main class="public-shell">
        <header class="public-topbar" data-controller="topbar">
          <%= link_to home_nav_path, class: "public-brand", data: { turbo_frame: "_top" } do %>
            <%= image_tag "lightvue-logo-white.png", alt: "Light Vue logo", class: "public-brand__logo" %>
            <span class="public-brand__meta">
              <span class="public-brand__name">Light Vue</span>
              <span class="public-brand__tagline">Curtains & Tracks for Trade Partners</span>
            </span>
          <% end %>

          <nav class="public-nav">
            <%= link_to "Home", home_nav_path, class: [ "public-nav__link", ("public-nav__link--active" if current_page?(home_nav_path)) ].compact.join(" "), data: { turbo_frame: "_top" } %>
            <%= link_to "Partners", partners_nav_path, class: [ "public-nav__link", ("public-nav__link--active" if current_page?(partners_nav_path)) ].compact.join(" "), data: { turbo_frame: "_top" } %>
            <%= link_to "Builders & Developers", builders_nav_path, class: [ "public-nav__link", ("public-nav__link--active" if current_page?(builders_nav_path)) ].compact.join(" "), data: { turbo_frame: "_top" } %>
            <% if admin_public %>
              <% if edit_mode %>
                <%= link_to "View Live", root_path, class: "public-nav__link", data: { turbo_frame: "_top" } %>
              <% else %>
                <%= link_to "Edit Pages", edit_pages_path, class: [ "public-nav__link", ("public-nav__link--active" if current_page?(edit_pages_path)) ].compact.join(" "), data: { turbo_frame: "_top" } %>
              <% end %>
              <%= link_to "Dashboard", dashboard_path, class: "public-nav__link", data: { turbo_frame: "_top" } %>
              <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "public-nav__link public-nav__link--button", form: { class: "inline-form" } %>
            <% else %>
              <%= link_to site_setting(:public_cta_login_label), new_user_session_path, class: [ "public-nav__link", ("public-nav__link--active" if current_page?(new_user_session_path)) ].compact.join(" "), data: { turbo_frame: "_top" } %>
            <% end %>
          </nav>
        </header>

        <% if notice.present? || alert.present? %>
          <div class="flash-stack flash-stack--public">
            <% if notice.present? %>
              <div class="flash flash--notice" data-controller="flash" data-flash-timeout-value="6000">
                <div class="flash__content"><%= notice %></div>
                <button type="button" class="flash__close" data-action="flash#close" aria-label="Dismiss notification">&times;</button>
              </div>
            <% end %>
            <% if alert.present? %>
              <div class="flash flash--alert" data-controller="flash" data-flash-timeout-value="9000">
                <div class="flash__content"><%= alert %></div>
                <button type="button" class="flash__close" data-action="flash#close" aria-label="Dismiss alert">&times;</button>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if [ "public_pages", "partners_editor" ].include?(controller_name) %>
          <%= yield %>
        <% else %>
          <section class="public-static card card--content">
            <%= yield %>
          </section>
        <% end %>

        <% unless controller_name == "partners_editor" && action_name == "home" %>
          <footer class="public-footer card">
            <% footer_tagline = if controller_name == "public_pages" && action_name == "home" && defined?(@home_content) && @home_content.present?
              @home_content.dig("texts", "footer_tagline").presence || site_setting(:public_footer_tagline)
            else
              site_setting(:public_footer_tagline)
            end %>
            <div class="public-footer__brand">
              <%= image_tag "lightvue-logo-white.png", alt: "Light Vue logo", class: "public-footer__logo" %>
              <p><%= footer_tagline %></p>
            </div>
            <div class="public-footer__contact">
              <p><a href="mailto:info@lightvue.com.au">E: info@lightvue.com.au</a></p>
              <p><a href="tel:+61431262042">P: 0431 262 042</a></p>
            </div>
            <div class="public-footer__legal">
              <%= link_to "Home", home_nav_path, data: { turbo_frame: "_top" } %>
              <%= link_to "Partners", partners_nav_path, data: { turbo_frame: "_top" } %>
              <%= link_to "Builders & Developers", builders_nav_path, data: { turbo_frame: "_top" } %>
              <%= link_to "Terms of Service", terms_path %>
              <%= link_to "Privacy Policy", privacy_path %>
              <p>
                Website designed by
                <%= link_to "Tudouke Studio", "https://tudouke.com", target: "_blank", rel: "noopener" %>
              </p>
            </div>
          </footer>
        <% end %>
      </main>
    <% end %>
  </body>
</html>
