<% page_key = "builders" %>
<% builders_texts = @page_content.fetch("texts", {}) %>
<% builders_arrays = @page_content.fetch("arrays", {}) %>
<% builders_images = @page_content.fetch("images", {}) %>
<% builders_styles = @page_content.fetch("styles", {}) %>

<%= form_with url: update_page_editor_path(page: page_key),
              method: :patch,
              html: { multipart: true, class: "partners-editor-shell" },
              data: {
                controller: "partners-editor",
                action: "submit->partners-editor#beforeSubmit",
                turbo: false,
                partners_editor_font_map_value: AppSetting::PUBLIC_FONT_STACKS.to_json,
                partners_editor_draft_pending_value: @draft_pending.to_s
              } do %>
  <%= hidden_field_tag :page_payload_json, @page_content.to_json, data: { partners_editor_target: "payload" } %>

  <%= render "toolbar", page_key: page_key, draft_pending: @draft_pending %>

  <section class="lv-hero lv-hero--builders">
    <div class="partners-editor-image" data-image-key="hero_image" data-action="click->partners-editor#pickImage">
      <%= image_tag builders_images.fetch("hero_image"), class: "lv-hero__image", alt: "Custom curtains in a modern lounge setting", data: { partners_editor_target: "imagePreview", image_key: "hero_image" } %>
    </div>
    <%= file_field_tag "images[hero_image]", accept: "image/*", class: "partners-editor-file", data: { partners_editor_target: "imageInput", image_key: "hero_image", action: "change->partners-editor#imageChanged" } %>
    <div class="lv-hero__veil"></div>
    <article class="lv-hero__content">
      <button type="button" class="partners-editor-image-button" data-image-key="hero_image" data-action="click->partners-editor#pickImage">Replace banner image</button>
      <p class="lv-kicker">Builders & Developers</p>
      <h1 contenteditable="true"
          class="partners-editor-field"
          style="<%= public_text_style(builders_styles, "hero_title") %>"
          data-partners-editor-target="editable"
          data-text-key="hero_title"
          data-style-key="hero_title"
          data-label="Hero title"
          data-action="click->partners-editor#selectEditable input->partners-editor#updateText"><%= builders_texts.fetch("hero_title") %></h1>
      <p class="lv-lead partners-editor-field"
         contenteditable="true"
         style="<%= public_text_style(builders_styles, "hero_lead") %>"
         data-partners-editor-target="editable"
         data-text-key="hero_lead"
         data-style-key="hero_lead"
         data-label="Hero subtitle"
         data-action="click->partners-editor#selectEditable input->partners-editor#updateText"><%= builders_texts.fetch("hero_lead") %></p>
      <div class="lv-actions">
        <%= link_to site_setting(:public_cta_contact_label), "#", class: "lv-pill", data: { turbo: false } %>
        <%= link_to site_setting(:public_cta_login_label), "#", class: "lv-pill lv-pill--dark", data: { turbo: false } %>
      </div>
    </article>
  </section>

  <section class="lv-section lv-section--split">
    <article class="lv-panel">
      <div class="partners-editor-image" data-image-key="split_image_one" data-action="click->partners-editor#pickImage">
        <%= image_tag builders_images.fetch("split_image_one"), alt: "Open plan living room with sheers", class: "lv-panel__image", data: { partners_editor_target: "imagePreview", image_key: "split_image_one" } %>
      </div>
      <%= file_field_tag "images[split_image_one]", accept: "image/*", class: "partners-editor-file", data: { partners_editor_target: "imageInput", image_key: "split_image_one", action: "change->partners-editor#imageChanged" } %>
    </article>
    <article class="lv-panel lv-panel--copy">
      <header class="lv-section__header">
        <p class="lv-kicker">Why It Matters</p>
        <h2 contenteditable="true"
            class="partners-editor-field"
            style="<%= public_text_style(builders_styles, "why_title") %>"
            data-partners-editor-target="editable"
            data-text-key="why_title"
            data-style-key="why_title"
            data-label="Why section title"
            data-action="click->partners-editor#selectEditable input->partners-editor#updateText"><%= builders_texts.fetch("why_title") %></h2>
      </header>
      <p contenteditable="true"
         class="partners-editor-field"
         style="<%= public_text_style(builders_styles, "why_lead") %>"
         data-partners-editor-target="editable"
         data-text-key="why_lead"
         data-style-key="why_lead"
         data-label="Why section lead"
         data-action="click->partners-editor#selectEditable input->partners-editor#updateText"><%= builders_texts.fetch("why_lead") %></p>
      <ul class="lv-bullet-list">
        <% builders_arrays.fetch("why_bullets", []).each_with_index do |bullet, index| %>
          <li contenteditable="true"
              class="partners-editor-field"
              style="<%= public_text_style(builders_styles, "why_bullets") %>"
              data-partners-editor-target="editable"
              data-list-key="why_bullets"
              data-list-index="<%= index %>"
              data-style-key="why_bullets"
              data-label="Why bullet"
              data-action="click->partners-editor#selectEditable input->partners-editor#updateText"><%= bullet %></li>
        <% end %>
      </ul>
    </article>
  </section>

  <section class="lv-section lv-section--split">
    <article class="lv-panel">
      <div class="partners-editor-image" data-image-key="split_image_two" data-action="click->partners-editor#pickImage">
        <%= image_tag builders_images.fetch("split_image_two"), alt: "Close-up of quality curtain fabric", class: "lv-panel__image", data: { partners_editor_target: "imagePreview", image_key: "split_image_two" } %>
      </div>
      <%= file_field_tag "images[split_image_two]", accept: "image/*", class: "partners-editor-file", data: { partners_editor_target: "imageInput", image_key: "split_image_two", action: "change->partners-editor#imageChanged" } %>
    </article>
    <article class="lv-panel">
      <h2 contenteditable="true"
          class="partners-editor-field"
          style="<%= public_text_style(builders_styles, "quote_title") %>"
          data-partners-editor-target="editable"
          data-text-key="quote_title"
          data-style-key="quote_title"
          data-label="Quote section title"
          data-action="click->partners-editor#selectEditable input->partners-editor#updateText"><%= builders_texts.fetch("quote_title") %></h2>
      <p contenteditable="true"
         class="partners-editor-field"
         style="<%= public_text_style(builders_styles, "quote_lead") %>"
         data-partners-editor-target="editable"
         data-text-key="quote_lead"
         data-style-key="quote_lead"
         data-label="Quote section lead"
         data-action="click->partners-editor#selectEditable input->partners-editor#updateText"><%= builders_texts.fetch("quote_lead") %></p>
      <ul class="lv-bullet-list">
        <% builders_arrays.fetch("quote_bullets", []).each_with_index do |bullet, index| %>
          <li contenteditable="true"
              class="partners-editor-field"
              style="<%= public_text_style(builders_styles, "quote_bullets") %>"
              data-partners-editor-target="editable"
              data-list-key="quote_bullets"
              data-list-index="<%= index %>"
              data-style-key="quote_bullets"
              data-label="Quote bullet"
              data-action="click->partners-editor#selectEditable input->partners-editor#updateText"><%= bullet %></li>
        <% end %>
      </ul>
      <div class="lv-actions">
        <%= link_to site_setting(:public_cta_contact_label), "#", class: "lv-pill", data: { turbo: false } %>
        <%= link_to site_setting(:public_cta_login_label), "#", class: "lv-pill lv-pill--dark", data: { turbo: false } %>
      </div>
    </article>
  </section>
<% end %>
