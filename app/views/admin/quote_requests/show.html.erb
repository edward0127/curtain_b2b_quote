<section class="hero hero--compact">
  <div>
    <p class="eyebrow">Admin <%= quote_or_order_label %></p>
    <h2><%= @quote_request.quote_number %></h2>
    <p class="lead">Submitted by <strong><%= @quote_request.user.email %></strong> on <%= l(@quote_request.created_at, format: :long) %>.</p>
  </div>
  <span class="status-pill status-pill--<%= @quote_request.status %>"><%= @quote_request.display_status %></span>
</section>

<section class="panel">
  <div class="panel-head">
    <h3><%= quote_or_order_label %> Metadata</h3>
    <div class="table-actions">
      <%= link_to "Printable", document_admin_quote_request_path(@quote_request), class: "button button--secondary" %>
      <%= link_to "Invoice PDF", invoice_admin_quote_request_path(@quote_request, format: :pdf), class: "button button--primary" %>
      <%= link_to "To Chinese Factory", to_chinese_factory_admin_quote_request_path(@quote_request), class: "button button--primary" %>
    </div>
  </div>

  <%= form_with model: [ :admin, @quote_request ], class: "form-grid" do |form| %>
    <div class="field">
      <%= form.label :customer_reference, "Customer reference" %>
      <%= form.text_field :customer_reference %>
    </div>
    <div class="field">
      <%= form.label :valid_until %>
      <%= form.date_field :valid_until %>
    </div>
    <div class="field field--full">
      <%= form.label :notes %>
      <%= form.text_area :notes, rows: 4 %>
    </div>
    <div class="actions field--full">
      <%= form.submit "Update #{quote_or_order_label}", class: "button button--secondary" %>
    </div>
  <% end %>
</section>

<section class="panel">
  <h3>Workflow Actions</h3>

  <% if @quote_request.order_workflow? %>
    <%= form_with url: update_status_admin_quote_request_path(@quote_request), method: :patch, class: "form-grid" do %>
      <div class="field">
        <%= label_tag :status, "Order status" %>
        <%= select_tag :status, options_for_select(QuoteRequest::ORDER_WORKFLOW_STATUSES.map { |status| [ QuoteRequest.status_label_for(status), status ] }, @quote_request.status) %>
      </div>
      <div class="actions field--full">
        <%= submit_tag "Update Status", class: "button button--primary" %>
      </div>
    <% end %>
  <% else %>
    <div class="actions">
      <% QuoteRequest::STATUS_TRANSITIONS.fetch(@quote_request.status, []).each do |target| %>
        <%= button_to QuoteRequest.status_label_for(target), update_status_admin_quote_request_path(@quote_request, status: target), method: :patch, class: "button button--primary" %>
      <% end %>
    </div>
  <% end %>
</section>

<section class="panel">
  <h3><%= quote_or_order_label(count: @quote_request.quote_items.size) %> Line Items</h3>
  <%= render "quote_requests/order_lines_sheet", quote_request: @quote_request, meta_label: (@quote_request.order_workflow? ? "Order" : "Quote") %>
</section>
