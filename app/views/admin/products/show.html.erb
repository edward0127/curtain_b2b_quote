<section class="hero hero--compact">
  <div>
    <p class="eyebrow">Catalog</p>
    <h2><%= @product.name %></h2>
    <p class="lead"><%= @product.description.presence || "No description." %></p>
  </div>
  <div class="table-actions">
    <%= link_to "Edit Product", edit_admin_product_path(@product), class: "button button--secondary" %>
  </div>
</section>

<% if @product.active? && @product.matrix_priced_template? && !@product.matrix_price_ready? %>
  <div class="flash flash--alert">
    This product is active, but no imported matrix pricing is currently available for its channel/type/style.
    It will not be usable in normal ordering flows until pricing is imported.
  </div>
<% end %>

<section class="detail-grid">
  <article class="detail-card">
    <h3>Product Details</h3>
    <% channel_label = case @product.pricing_channel.to_s.strip.downcase
    when "b2b" then "B2B"
    when "b2c" then "B2C"
    else "Not set"
    end %>
    <p><strong>SKU</strong> <span><%= @product.sku.presence || "-" %></span></p>
    <p><strong>Pricing mode</strong> <span><%= @product.pricing_mode.humanize %></span></p>
    <p><strong>Channel</strong> <span><%= channel_label %></span></p>
    <p><strong>Product type</strong> <span><%= @product.product_type.presence || "-" %></span></p>
    <p><strong>Style</strong> <span><%= @product.style_name.presence || "-" %></span></p>
    <p><strong>Base price</strong> <span><%= number_to_currency(@product.base_price, unit: "AUD ") %></span></p>
    <p><strong>Status</strong> <span><%= @product.active? ? "Active" : "Inactive" %></span></p>
  </article>
  <article class="detail-card">
    <h3>Usage</h3>
    <p><strong><%= quote_or_order_label(count: 2) %> items</strong> <span><%= @product.quote_items.count %></span></p>
    <p><strong>Pricing rules</strong> <span><%= @pricing_rules.count %></span></p>
  </article>

  <article class="detail-card">
    <h3>Inventory Mappings</h3>
    <% mappings = [
      [ "Track", @product.track_inventory_item ],
      [ "Hook", @product.hook_inventory_item ],
      [ "Bracket", @product.bracket_inventory_item ],
      [ "Wand", @product.wand_inventory_item ],
      [ "End cap", @product.end_cap_inventory_item ],
      [ "Stopper", @product.stopper_inventory_item ],
      [ "Wand hook", @product.wand_hook_inventory_item ]
    ] %>
    <% mappings.each do |label, item| %>
      <% item_label = item.present? ? (item.sku.present? ? "#{item.name} (#{item.sku})" : item.name) : "None" %>
      <p><strong><%= label %></strong> <span><%= item_label %></span></p>
    <% end %>
  </article>
</section>
