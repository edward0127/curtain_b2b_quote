<section class="hero hero--compact">
  <div>
    <p class="eyebrow">Catalog</p>
    <h2>Products</h2>
    <p class="lead">Manage active products, customer channel (B2B/B2C), and legacy-safe inventory mappings.</p>
  </div>
  <div class="table-actions">
    <% archived_toggle_label = if @archived_imported_count.positive?
      "Show Archived PB Templates (#{@archived_imported_count})"
    else
      "Show Archived PB Templates"
    end %>
    <% if @show_archived_imported %>
      <%= link_to "Hide Archived Imported Templates", admin_products_path, class: "button button--secondary" %>
    <% else %>
      <%= link_to archived_toggle_label, admin_products_path(show_archived_imported: 1), class: "button button--secondary" %>
    <% end %>
    <%= link_to "New Product", new_admin_product_path, class: "button button--primary" %>
  </div>
</section>

<section class="panel">
  <% if @show_archived_imported %>
    <p class="muted">Archived importer-managed <code>PB-*</code> templates are shown below for historical reference only. They are preserved for older quotes and orders and remain hidden from the default list.</p>
  <% else %>
    <p class="muted">Inactive importer-managed <code>PB-*</code> templates are hidden from the default list so archived historical templates do not crowd active catalog management.</p>
  <% end %>

  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>SKU</th>
          <th>Pricing Mode</th>
          <th>Channel</th>
          <th>Pricing</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td><%= link_to product.name, admin_product_path(product) %></td>
            <td><%= product.sku.presence || "-" %></td>
            <td><%= product.pricing_mode.humanize %></td>
            <% channel_key = product.pricing_channel.to_s.strip.downcase %>
            <% channel_label, channel_class = case channel_key
            when "b2b" then [ "B2B", "b2b" ]
            when "b2c" then [ "B2C", "b2c" ]
            else [ "Not set", "not_set" ]
            end %>
            <td><span class="status-pill status-pill--<%= channel_class %>"><%= channel_label %></span></td>
            <td><%= @pricing_labels[product.id] %></td>
            <% status_label = if product.archived_imported_pricebook_template?
              "Archived PB template"
            elsif product.active?
              "Active"
            else
              "Inactive"
            end %>
            <td><%= status_label %></td>
            <td class="table-actions">
              <%= link_to "Preview price", preview_price_admin_product_path(product), class: "button button--secondary button--small" %>
              <%= link_to "Edit", edit_admin_product_path(product), class: "button button--secondary button--small" %>
              <%= button_to "Delete", admin_product_path(product), method: :delete, class: "button button--danger button--small", form: { class: "inline-form", data: { turbo_confirm: "Delete this product?" } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
