<section class="lv-hero lv-hero--builders">
  <%= image_tag "public-e-40.jpg", class: "lv-hero__image", alt: "Custom curtains in a modern lounge setting" %>
  <div class="lv-hero__veil"></div>
  <article class="lv-hero__content">
    <p class="lv-kicker">Builders & Developers</p>
    <h1>The finishing touch that completes every project</h1>
    <p class="lv-lead">Trade-focused curtains and tracks for builders and developers.</p>
    <div class="lv-actions">
      <%= link_to "Get in touch", root_path(anchor: "get-in-touch"), class: "lv-pill", data: { turbo_frame: "_top" } %>
      <%= link_to "B2B Login", new_user_session_path, class: "lv-pill lv-pill--dark", data: { turbo_frame: "_top" } %>
    </div>
  </article>
</section>

<section class="lv-section lv-section--split">
  <article class="lv-panel">
    <%= image_tag "public-e-3.jpg", alt: "Open plan living room with sheers", class: "lv-panel__image" %>
  </article>
  <article class="lv-panel lv-panel--copy">
    <header class="lv-section__header">
      <p class="lv-kicker">Why It Matters</p>
      <h2>Curtains shape how finished homes feel</h2>
    </header>
    <p>Well-fitted sheers and blockouts add warmth, improve presentation, and complete the space.</p>
    <ul class="lv-bullet-list">
      <li>Better presentation at handover</li>
      <li>Stronger buyer appeal</li>
      <li>Ready-to-live-in feel</li>
    </ul>
  </article>
</section>

<section class="lv-section lv-section--split">
  <article class="lv-panel">
    <%= image_tag "public-e-37.jpg", alt: "Close-up of quality curtain fabric", class: "lv-panel__image" %>
  </article>
  <article class="lv-panel">
    <h2>Ready to quote your next development?</h2>
    <p>Fast pricing, practical communication, and reliable delivery.</p>
    <ul class="lv-bullet-list">
      <li>True wholesale pricing</li>
      <li>Quick turnaround</li>
      <li>Tailored service to your project specs</li>
    </ul>
    <div class="lv-actions">
      <%= link_to "Get in touch", root_path(anchor: "get-in-touch"), class: "lv-pill", data: { turbo_frame: "_top" } %>
      <%= link_to "B2B Login", new_user_session_path, class: "lv-pill lv-pill--dark", data: { turbo_frame: "_top" } %>
    </div>
  </article>
</section>
