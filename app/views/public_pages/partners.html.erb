<section class="lv-hero lv-hero--partners">
  <%= image_tag "public-e-1.jpg", class: "lv-hero__image", alt: "Interior project with full-height sheer curtains" %>
  <div class="lv-hero__veil"></div>
  <article class="lv-hero__content">
    <p class="lv-kicker">Partners</p>
    <h1>Who we work with</h1>
    <p class="lv-lead">Long-term trade partnerships built on reliability.</p>
    <div class="lv-actions">
      <%= link_to "Get in touch", root_path(anchor: "get-in-touch"), class: "lv-pill", data: { turbo_frame: "_top" } %>
      <%= link_to "Builders & Developers", builders_path, class: "lv-pill lv-pill--dark", data: { turbo_frame: "_top" } %>
    </div>
  </article>
</section>

<section class="lv-section">
  <header class="lv-section__header">
    <p class="lv-kicker">Partner Types</p>
    <h2>Who we work with across projects</h2>
  </header>
  <div class="lv-partner-grid">
    <article>Developers</article>
    <article>Builders</article>
    <article>Architects</article>
    <article>Interior Designers</article>
    <article>Window Furnishing Businesses</article>
    <article>Real Estate Professionals</article>
  </div>
</section>

<section class="lv-section lv-section--split">
  <article class="lv-panel">
    <%= image_tag "public-e-12.jpg", alt: "Bedroom styled with sheers", class: "lv-panel__image" %>
  </article>
  <article class="lv-panel lv-panel--copy">
    <h2>Built for repeat projects</h2>
    <p>Clear quoting, practical communication, and dependable delivery.</p>
    <ul class="lv-bullet-list">
      <li>Clear updates from quote to install</li>
      <li>Consistent quality across projects</li>
      <li>Delivery you can plan around</li>
    </ul>
    <div class="lv-actions">
      <%= link_to "Get in touch", root_path(anchor: "get-in-touch"), class: "lv-pill", data: { turbo_frame: "_top" } %>
      <%= link_to "B2B Login", new_user_session_path, class: "lv-pill lv-pill--dark", data: { turbo_frame: "_top" } %>
    </div>
  </article>
</section>
