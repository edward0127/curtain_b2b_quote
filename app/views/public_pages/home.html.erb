<section class="lv-hero">
  <%= image_tag "public-new-background-1.png", class: "lv-hero__image", alt: "Warm-toned curtains in a modern interior" %>
  <div class="lv-hero__veil"></div>
  <article class="lv-hero__content">
    <p class="lv-kicker">LIGHT VUE</p>
    <h1>Your trade partner for exceptional interiors.</h1>
    <p class="lv-lead">Wholesale curtains, sheers and tracks for builders, developers and interior professionals.</p>
    <ul class="lv-hero__signals">
      <li>Wholesale pricing</li>
      <li>Reliable lead times</li>
      <li>Consistent finish</li>
    </ul>
    <div class="lv-actions">
      <%= link_to "Get in touch", "#get-in-touch", class: "lv-pill", data: { turbo: false } %>
      <%= link_to "B2B Login", new_user_session_path, class: "lv-pill lv-pill--dark", data: { turbo_frame: "_top" } %>
    </div>
  </article>
</section>

<section class="lv-section">
  <header class="lv-section__header">
    <p class="lv-kicker">Why Light Vue</p>
    <h2>Simple, reliable supply for trade projects.</h2>
  </header>

  <div class="lv-feature-grid">
    <article class="lv-feature-card">
      <%= image_tag "public-e-14.jpg", alt: "S-wave curtain detail" %>
      <div>
        <h3>Trade-only supply</h3>
        <p>For builders, developers, designers and local curtain businesses.</p>
      </div>
    </article>
    <article class="lv-feature-card">
      <%= image_tag "public-e-3.jpg", alt: "Sheer curtains in a living room" %>
      <div>
        <h3>Curated range</h3>
        <p>A focused fabric range selected for repeatable results.</p>
      </div>
    </article>
    <article class="lv-feature-card">
      <%= image_tag "public-e-37.jpg", alt: "Curtain fabric in hand" %>
      <div>
        <h3>Heat-set pleats</h3>
        <p>Smooth, even folds that hold their shape over time.</p>
      </div>
    </article>
    <article class="lv-feature-card">
      <%= image_tag "public-e-1.jpg", alt: "Open space with sheers" %>
      <div>
        <h3>Practical support</h3>
        <p>Lean service focused on what helps projects move.</p>
      </div>
    </article>
  </div>
</section>

<section class="lv-section">
  <header class="lv-section__header">
    <p class="lv-kicker">Products</p>
    <h2>Core range for trade projects</h2>
  </header>

  <div class="lv-product-grid">
    <article class="lv-product-card">
      <%= image_tag "public-e-12.jpg", alt: "Bedroom with sheer curtains" %>
      <div>
        <h3>Curtain Tracks</h3>
        <p>Cut-to-size tracks for smooth operation.</p>
      </div>
    </article>
    <article class="lv-product-card">
      <%= image_tag "public-e-14.jpg", alt: "Pleated sheer curtain" %>
      <div>
        <h3>S-Wave Curtains</h3>
        <p>Clean, modern lines with consistent drape.</p>
      </div>
    </article>
    <article class="lv-product-card">
      <%= image_tag "public-e-40.jpg", alt: "Floor to ceiling curtain in neutral interior" %>
      <div>
        <h3>Pinch Pleat Curtains</h3>
        <p>Classic, tailored finish for premium interiors.</p>
      </div>
    </article>
    <article class="lv-product-card">
      <%= image_tag "public-e-37.jpg", alt: "Fabric texture closeup" %>
      <div>
        <h3>Fabric Options</h3>
        <p>Selected sheers and blockouts for dependable performance.</p>
      </div>
    </article>
  </div>
</section>

<section id="get-in-touch" class="lv-section lv-section--contact-form">
  <div class="lv-contact-layout">
    <div class="lv-contact-intro">
      <h2>Get in Touch</h2>
      <h3>Planning a project?</h3>
      <p>Tell us what you need and our trade team will respond.</p>
      <p><a href="mailto:info@lightvue.com.au">E: info@lightvue.com.au</a></p>
      <p><a href="tel:+61431262042">P: 0431 262 042</a></p>
    </div>

    <div class="lv-contact-form-wrap">
      <% if @contact_form.errors.any? %>
        <div class="lv-contact-errors">
          <p>Please review the form details:</p>
          <ul>
            <% @contact_form.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @contact_form, url: public_contact_path, method: :post, class: "lv-contact-form", data: { controller: "submit-state", action: "turbo:submit-start->submit-state#start turbo:submit-end->submit-state#end", submit_state_submitting_label_value: "Sending...", submit_state_submitting_message_value: "Sending your message. Please wait..." } do |f| %>
        <p class="lv-form-row lv-form-row--label">Name</p>
        <div class="lv-form-row lv-form-row--two">
          <label class="lv-form-field">
            <span>First Name <em>(required)</em></span>
            <%= f.text_field :first_name, required: true, autocomplete: "given-name" %>
          </label>
          <label class="lv-form-field">
            <span>Last Name <em>(required)</em></span>
            <%= f.text_field :last_name, required: true, autocomplete: "family-name" %>
          </label>
        </div>

        <label class="lv-form-field">
          <span>Email <em>(required)</em></span>
          <%= f.email_field :email, required: true, autocomplete: "email" %>
        </label>

        <label class="lv-form-checkbox">
          <%= f.check_box :subscribe_updates %>
          <span>Sign up for news and updates</span>
        </label>

        <label class="lv-form-field">
          <span>Company <em>(required)</em></span>
          <%= f.text_field :company, required: true, autocomplete: "organization" %>
        </label>

        <label class="lv-form-field">
          <span>Message <em>(required)</em></span>
          <%= f.text_area :message, required: true, rows: 6 %>
        </label>

        <button type="submit" class="lv-form-submit button--with-spinner" data-submit-state-target="button">
          <span data-submit-state-target="label">Submit</span>
          <span class="button__spinner" data-submit-state-target="spinner" hidden></span>
        </button>
        <p class="lv-form-status" data-submit-state-target="message" role="status" aria-live="polite"></p>
      <% end %>
    </div>
  </div>
</section>
