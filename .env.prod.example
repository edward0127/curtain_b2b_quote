# Required
RAILS_ENV=production
RAILS_MASTER_KEY=replace_with_config_master_key
RAILS_LOG_LEVEL=info

# Host port to bind container port 80 to (avoid conflicts with existing services)
APP_PORT_BIND=3012

# Seed admin credentials used by `script/deploy.sh bootstrap`
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# Optional bootstrap defaults for first AppSetting creation
APP_HOST=example.com
APP_PROTOCOL=https
APP_PORT=443
MAIL_FROM_EMAIL=no-reply@example.com
QUOTE_RECEIVER_EMAIL=sales@example.com
MAILGUN_DOMAIN=mg.example.com
MAILGUN_SMTP_USERNAME=postmaster@mg.example.com
MAILGUN_SMTP_PASSWORD=
MAILGUN_SMTP_ADDRESS=smtp.mailgun.org
MAILGUN_SMTP_PORT=587

# Optional: Active Storage backend
# Use "amazon" for S3-backed Active Storage, "local" to keep disk storage.
ACTIVE_STORAGE_SERVICE=amazon

# AWS credentials (or provide an IAM role to the server and leave keys blank)
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=your-active-storage-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Public page image editor uploads (draft/publish images)
PUBLIC_UPLOAD_S3_BUCKET=your-public-page-images-bucket
PUBLIC_UPLOAD_S3_REGION=ap-southeast-2

# Optional: CDN/CloudFront domain to serve uploaded public-page images
# Example: https://cdn.example.com
PUBLIC_UPLOAD_ASSET_HOST=

# Optional for S3-compatible endpoints (MinIO, etc.)
PUBLIC_UPLOAD_S3_ENDPOINT=
PUBLIC_UPLOAD_S3_FORCE_PATH_STYLE=false
